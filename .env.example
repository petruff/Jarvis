# =============================================================================
# Jarvis Platform - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env to version control!

# =============================================================================
# LLM Providers
# =============================================================================
# Claude / Anthropic — PRIMARY LLM
# Get your key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here
# Model override (default: claude-3-5-sonnet-20241022)
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# DeepSeek (Fallback - high-volume cost-effective tasks)
DEEPSEEK_API_KEY=sk_your_deepseek_key_here

# OpenAI (Fallback for high-complexity tasks)
OPENAI_API_KEY=sk-your_openai_key_here

# Google Gemini (Alternative LLM)
GEMINI_API_KEY=your_gemini_key_here

# =============================================================================
# Messaging & Communication
# =============================================================================
# Telegram Bot Token (from @BotFather on Telegram)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# WhatsApp Integration (Twilio or Baileys - optional)
WHATSAPP_TOKEN=your_whatsapp_token_here

# =============================================================================
# Voice & Speech
# =============================================================================
# ElevenLabs for text-to-speech and speech-to-text
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL credentials (used by docker-compose)
DATABASE_PASSWORD=jarvis_dev_password

# Neo4j (Graph database for semantic memory)
NEO4J_PASSWORD=jarvis_neo4j_password

# Redis (Optional password for production)
REDIS_PASSWORD=

# Qdrant (Vector database for episodic memory)
QDRANT_API_KEY=qdrant_dev_key

# =============================================================================
# Security & Authentication
# =============================================================================
# JWT Secret for API authentication (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=dev-secret-key-change-for-production-min-32-chars

# =============================================================================
# Application Configuration
# =============================================================================
# Node environment
NODE_ENV=development

# API URLs (for development)
BACKEND_URL=http://localhost:3000
GATEWAY_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173

# =============================================================================
# Monitoring & Observability
# =============================================================================
# Grafana admin password
GRAFANA_PASSWORD=admin

# Grafana domain (for production)
GRAFANA_DOMAIN=grafana.yourdomain.com

# API domain (for production)
API_DOMAIN=api.yourdomain.com

# =============================================================================
# AWS Configuration (if deploying to AWS)
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_ECR_REGISTRY=your-account.dkr.ecr.region.amazonaws.com

# =============================================================================
# Google Cloud Configuration (if deploying to GCP)
# =============================================================================
GCP_PROJECT_ID=your-project-id
GCP_SERVICE_ACCOUNT_KEY=path/to/service-account-key.json

# =============================================================================
# Azure Configuration (if deploying to Azure)
# =============================================================================
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=your-resource-group
AZURE_CONTAINER_REGISTRY=yourregistry.azurecr.io

# =============================================================================
# Logging & Debug
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Enable debug logging
DEBUG=false

# =============================================================================
# Features & Flags
# =============================================================================
# Enable autonomy mode (automatic task execution)
ENABLE_AUTONOMY=true

# Enable consciousness loop (every 6 hours)
ENABLE_CONSCIOUSNESS_LOOP=true

# Enable nightly learning (2 AM)
ENABLE_NIGHTLY_LEARNING=true

# Enable multi-channel integration
ENABLE_TELEGRAM=true
ENABLE_WHATSAPP=false

# =============================================================================
# Custom Configuration
# =============================================================================
# Add any additional custom variables below:

# =============================================================================
# JARVIS Gateway — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is gitignored.
# =============================================================================

# =============================================================================
# TELEGRAM
# =============================================================================
# Telegram Bot Token — Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram numeric user ID (not username)
# Find it by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=your_telegram_user_id_number

# =============================================================================
# WHATSAPP (optional)
# =============================================================================
# Your WhatsApp number in format: PHONENUMBER@c.us
# Example: 15551234567@c.us
# Leave empty to disable WhatsApp channel
WHATSAPP_ALLOWED_NUMBERS=

# =============================================================================
# WEB SEARCH (optional)
# =============================================================================
# Brave Search API key — for search capabilities
# Get your key: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# =============================================================================
# SYSTEM CONFIG
# =============================================================================
NODE_ENV=development
LOG_LEVEL=info
WORKSPACE_DIR=./workspace
MEMORY_DIR=./memory

# =============================================================================
# BACKEND BRIDGE
# =============================================================================
# URL of the jarvis-backend service
JARVIS_BACKEND_URL=http://127.0.0.1:3000

# =============================================================================
# JARVIS Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — it is gitignored.
# =============================================================================

# =============================================================================
# LLM PROVIDERS (at least one required)
# =============================================================================

# DeepSeek — Primary LLM (recommended, very cost-effective)
# Get your key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk_your_deepseek_key_here

# OpenAI — Used for TTS (text-to-speech) and embeddings
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Google Gemini — Alternative/vision LLM
# Get your key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Moonshot (Kimi) — Optional alternative LLM
# Get your key: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your_moonshot_key_here

# =============================================================================
# VOICE
# =============================================================================

# OpenAI voice model to use for TTS
# Options: alloy, echo, fable, onyx, nova, shimmer
OPENAI_VOICE=onyx

# =============================================================================
# MESSAGING CHANNELS
# =============================================================================

# Telegram Bot Token — Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram username (without @) — only this user can command JARVIS
OWNER_TELEGRAM=your_telegram_username

# Your WhatsApp number in format: PHONENUMBER@c.us (e.g. 15551234567@c.us)
# Only this number can interact via WhatsApp
OWNER_PHONE=your_phone_number_here

# =============================================================================
# EMAIL (optional — enables email polling channel)
# =============================================================================

# Gmail address JARVIS monitors for commands
GMAIL_USER=your_email@gmail.com

# Gmail App Password (NOT your regular password)
# Create at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your_gmail_app_password

# Comma-separated list of allowed sender emails
EMAIL_ALLOWLIST=your_email@gmail.com

# How often to poll for new emails (milliseconds, default: 5 min)
EMAIL_POLL_INTERVAL_MS=300000

# =============================================================================
# WEB SEARCH
# =============================================================================

# Brave Search API — for web search tools
# Get your key: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# =============================================================================
# INTEGRATIONS (optional)
# =============================================================================

# GitHub Personal Access Token — for GitHub operations via Jarvis
# Create at: https://github.com/settings/tokens (needs repo scope)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_github_token

# Composio API key — for 250+ app integrations
# Get your key: https://app.composio.dev/
COMPOSIO_API_KEY=ak_your_composio_key

# Obsidian vault path (for note-taking integration)
OBSIDIAN_VAULT_PATH=C:\Users\YourUser\Documents\ObsidianVault

# =============================================================================
# RATE LIMITER (prevent runaway API costs)
# =============================================================================

# Max LLM calls per minute
RATE_LIMIT_PER_MINUTE=100

# Max LLM calls per day
RATE_LIMIT_DAILY=5000

# Max spend in USD per day (circuit breaker)
RATE_LIMIT_COST_USD=50.00

# =============================================================================
# APPLICATION
# =============================================================================
NODE_ENV=development
